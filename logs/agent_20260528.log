s': 512}, 'total_tokens': 979}}, id='lc_run--019e6f35-8378-7920-ae40-ddff56ac78d8-0', tool_calls=[{'name': 'search_memory', 'args': {'query': '服装偏好（风格、尺码、颜色、品牌、面料、预算范围）'}, 'id': 'call_d0038c501a0f4bc5b253db', 'type': 'tool_call'}], invalid_tool_calls=[]), ToolMessage(content='未找到相关记忆', name='search_memory', tool_call_id='call_d0038c501a0f4bc5b253db')]]}}, 'run_id': '019e6f35-8914-72f1-8964-32a1f39dcc7b', 'name': 'ChatTongyi', 'tags': ['seq:step:1'], 'metadata': {'thread_id': '2026-05-28_23-30-23', 'ls_integration': 'langchain_chat_model', 'langgraph_step': 4, 'langgraph_node': 'react_agent', 'langgraph_triggers': ('branch:to:react_agent',), 'langgraph_path': ('__pregel_pull', 'react_agent'), 'langgraph_checkpoint_ns': 'react_agent:b83b77e5-4470-4973-7ad6-915393552e63', 'checkpoint_ns': 'react_agent:b83b77e5-4470-4973-7ad6-915393552e63', 'ls_provider': 'tongyi', 'ls_model_type': 'chat', 'ls_model_name': 'qwen-max'}, 'parent_ids': ['019e6f35-7f5c-7063-84f7-393722cc3aef', '019e6f35-8908-7b91-9bf2-03cf1081993a']}
